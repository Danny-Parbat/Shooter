import pygame
from sys import exit

def display_score():
    a=1
    current_time = int(pygame.time.get_ticks() / 1000) - start_time  #current time is the time since the game started
    score_surface = test_font.render(f'Score: {current_time}',False, (64,64,64))   #render the score as a surface
    score_rect = score_surface.get_rect(center = (400,50))    #create a rectangle for the score center it
    screen.blit(score_surface, score_rect)   #position of the score

pygame.init()

screen = pygame.display.set_mode((800, 600))   #create a window 
pygame.display.set_caption("Mario")   #set the title of the window
clock = pygame.time.Clock() #controls fps
test_font= pygame.font.Font('font/Minecraft.ttf',50)
game_active = False
start_time = 0

sky_surface = pygame.image.load('graphics/Sky.png').convert()
ground_surface = pygame.image.load('graphics/ground.png').convert()

# score_surface = test_font.render('Mario',False, (64,64,64))
# score_rect = score_surface.get_rect(center = (400,50))    #create a rectangle for the score center it

snail_surface = pygame.image.load('graphics/snail/snail1.png').convert_alpha()
snail_rect = snail_surface.get_rect(bottomleft= (600,480)) #create a rectangle for the snail

player_surface = pygame.image.load('graphics/Player/player_walk_1.png').convert_alpha()
player_rect = player_surface.get_rect(bottomleft = (80,470))  #create a rectangle for the player
player_gravity = 0

player_stand = pygame.image.load('graphics/Player/player_stand.png').convert_alpha()
player_stand=pygame.transform.scale2x(player_stand)   #scale the player stand image
player_stand_rect = player_stand.get_rect(center = (400,200))


while True: #keep running the game 
    for event in pygame.event.get(): #check for events
        if event.type == pygame.QUIT: #if the user clicks the close button
            pygame.quit() #quit the game
            exit() #exit the program

        if game_active:  
            if event.type == pygame.MOUSEBUTTONDOWN: #if the user clicks the mouse button
                if player_rect.collidepoint(event.pos) and player_rect.bottom == 470:
                    player_gravity = -20

            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_SPACE:  #if the space key is pressed
                    if player_rect.bottom == 470:   #if player is on the ground   
                        player_gravity = -20   #make the player jump by setting gravity to a negative value

            # if event.type == pygame.KEYUP:
            #     print("Key released")

        else:
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_SPACE:  #if the space key is pressed
                    game_active = True #restart the game
                    snail_rect.left = 800   #move the snail back to the right side of the screen
                    start_time = int(pygame.time.get_ticks() / 1000) #reset the start time

    if game_active:
        screen.blit(sky_surface, (-100,-250))   #block image transfer (put one surface on another)
        screen.blit(ground_surface, (0, 470))     #0 from the left & 470 from the top

        # pygame.draw.rect(screen, '#c0e8ec', score_rect)   #draw a rectangle around the score
        # pygame.draw.rect(screen, '#c0e8ec', score_rect, 10)
        display_score()   #call the function to display the score
        #pygame.draw.line(screen, "Gold", (0,0),pygame.mouse.get_pos(),6)   #draw a line from the top left to the bottom right corner)

        # screen.blit(score_surface, score_rect)
        snail_rect.x -= 8   #move the snail to the left

        if snail_rect.right <= 0:   #if the snail goes off the screen
            snail_rect.left = 800   #move it back to the right side of the screen
    
        screen.blit(snail_surface, snail_rect)  #position of the snail

        #player:
        player_gravity += 1    #add gravity to the player
        player_rect.y += player_gravity   #move the player down by the gravit
        if player_rect.bottom >= 470:
            player_rect.bottom = 470   #keep the player on the ground

        if player_rect.top<=0:
            player_rect.top = 0    #keep the player from going above the screen
        screen.blit(player_surface, player_rect)   #position of the player

        #keys=pygame.key.get_pressed()
    # if keys[pygame.K_SPACE]:
            #print("Jump")

        #if player_rect.colliderect(snail_rect):    #check for collision between player and snail
            #print("Collision")

        #collisions:
        if snail_rect.colliderect(player_rect): #check for collision between player and snail
            game_active = False #end the game

    else:
        # game_over_surface = pygame.image.load('graphics/gameover.png').convert_alpha()
        # game_over_rect = game_over_surface.get_rect(bottomright= (800,600))   #center the game over text
        # screen.blit(game_over_surface, game_over_rect)   #position of the game over text

        screen.fill((94,129,162))   #fill the screen with a color
        screen.blit(player_stand, player_stand_rect)   #position of the player stand image
        




    pygame.display.update() #update the display
    clock.tick(60) #set the frame rate to 60fps


